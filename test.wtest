import cultivos.*
import estados.*
import personaje.*
import wollok.game.*

describe "Test sobre sembrar, regar y cosechar" {
  method initialize() {
        game.clear()
        padme.plantasCosechadas().clear()
        padme.position(game.at(5,5))
        game.addVisual(padme) 
    }
  test "Padme siembra ,riega y cosecha un Maiz" {
        const maiz = new Maiz(position = padme.position())
        padme.sembrar(maiz)
        assert.notThat(maiz.estaLista())
        padme.regar()
        assert.that(maiz.estaLista())
        padme.cosechar()
        assert.equals([maiz], padme.plantasCosechadas())
      }
  test "Padme siembra ,riega y cosecha tambien Trigo" {
        const maiz = new Maiz(position = padme.position())
        padme.sembrar(maiz)
        padme.regar()
        padme.cosechar()
        padme.position(game.at(6,5))
        const trigo = new Trigo(position = padme.position())
        padme.sembrar(trigo)
        padme.regar()
        padme.regar()
        padme.cosechar()
        assert.equals([maiz,trigo], padme.plantasCosechadas())
        }
  
  test "Padme siembra ,riega y cosecha Tomaco" {  
        const tomaco = new Tomaco(position = padme.position())
        padme.sembrar(tomaco)
        assert.that(tomaco.estaLista())
        padme.regar()
        padme.position(tomaco.position())
        padme.cosechar()
        assert.equals([tomaco], padme.plantasCosechadas())
        
  }
}

describe "Test sobre la evolucion y su valor" {
    method initialize() 
        const maiz= new Maiz(position = game.at(0,0))
        const trigo= new Trigo(position = game.at(0,0))
        const tomaco= new Tomaco(position = game.at(0,0))
    test "Evoluvion y valor del Maiz" {
      assert.notThat(maiz.estaLista())
      maiz.serRegada()
      assert.that(maiz.estaLista())
      assert.equals(150, maiz.valor())
      
    }
    test "Evoluvion y valor del Trigo" {
        assert.equals(0, trigo.valor())
        assert.notThat(trigo.estaLista())
        trigo.serRegada()
        assert.equals(0, trigo.valor())
        assert.notThat(trigo.estaLista())
        trigo.serRegada()
        assert.equals(100, trigo.valor())
        assert.that(trigo.estaLista())
        trigo.serRegada() 
        assert.equals(200, trigo.valor())
        assert.that(trigo.estaLista())
    }

    test "Evolucion y valor del Tomaco" {
      tomaco.serRegada()
      assert.equals(80, tomaco.valor())
    }
}

describe "Test sobre Ventas" {
  const mercado1= new Mercado(position = game.at(2,2), monedas = 1000)
  const mercado2 = new Mercado(position = game.at(3,3), monedas = 10)
  const maiz = new Maiz(position = game.at(0,0))

  method initialize() {
        game.clear()
        maiz.serRegada()
        padme.plantasCosechadas().clear()
        padme.plantasCosechadas().add(maiz)
    }

    test "Padme vende sin problemas" {
        padme.position(game.at(2,2))
        game.addVisual(mercado1)
        game.addVisual(padme)
        padme.vender()
        assert.equals(150, padme.dinero())
        assert.equals(850, mercado1.monedas() )
        assert.that(padme.plantasCosechadas().isEmpty()) 
    }

    test "Padme intenta vender pero el mercado tiene poco dinero" {
        padme.position(game.at(3,3))
        game.addVisual(mercado2)
        game.addVisual(padme)
        assert.throwsException({ padme.vender() })
        assert.equals(0, padme.dinero())
        assert.equals(10, mercado2.monedas())
        assert.notThat(padme.plantasCosechadas().isEmpty())
    }
    
    test "Padme intenta vender pero no esta sobre un mercado" {
        padme.position(game.at(4,4))
        game.addVisual(padme)
        assert.throwsException({ padme.vender() })
    }
}

describe "Test sobre el funcionamiento del Aspersor" {
    const aspersor = new Aspersor(position = game.at(2,2))
    const maizCercano = new Maiz(position = game.at(2,3)) 
    const maizLejano = new Maiz(position = game.at(4,4))  

    method initialize() {
        game.clear()
        game.addVisual(aspersor)
        game.addVisual(maizCercano)
        game.addVisual(maizLejano)
    }

    test "El aspersor riega correctamente" {
        assert.notThat(maizCercano.estaLista())
        aspersor.regar()
        assert.that(maizCercano.estaLista())
    }

    test "El aspersor esta fuera de alcance" {
        assert.notThat(maizLejano.estaLista())
        aspersor.regar()
        assert.notThat(maizLejano.estaLista())
    }
}
